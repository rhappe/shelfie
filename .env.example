# Copy this file to .env and fill in the values before running docker compose.

# Required: PostgreSQL credentials
POSTGRES_USER=shelfie
POSTGRES_PASSWORD=changeme

# Required: JWT signing secret (use a long random string)
JWT_SECRET=changeme

# Optional: JWT token lifetime in days (default: 90)
# JWT_EXPIRY_DAYS=90

# Optional: override default ports
# SERVER_PORT=8080
# WEB_PORT=80
